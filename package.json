{
  "name": "@nghiadhd/tizenanime",
  "appName": "TizenAnime",
  "version": "1.0.11",
  "description": "Watch anime from Wibu47 on your Samsung TV",
  "packageType": "app",
  "appPath": "app/index.html",
  "serviceFile": "dist/service.js",
  "scripts": {
    "build": "esbuild service/index.js --bundle --platform=node --target=node12 --outfile=dist/service.js",
    "dev": "concurrently \"node service/index.js\" \"npx serve app -l 3000 --cors\"",
    "prepublishOnly": "npm run build",
    "version": "node scripts/bump-version.js",
    "release:patch": "npm version patch --no-git-tag-version && npm publish",
    "release:minor": "npm version minor --no-git-tag-version && npm publish",
    "release:major": "npm version major --no-git-tag-version && npm publish"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "app/",
    "dist/"
  ],
  "keys": [
    "MediaPlayPause",
    "MediaPlay",
    "MediaPause",
    "MediaStop",
    "MediaFastForward",
    "MediaRewind"
  ],
  "devDependencies": {
    "concurrently": "^8.2.0",
    "esbuild": "^0.21.0"
  }
}
